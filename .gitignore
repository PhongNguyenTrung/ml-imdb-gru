# Project-specific: data and artifacts (large, not checkpointable in git)
# Leading slash anchors the pattern to the repo root — otherwise `data/`
# would also match `src/imdb_gru/data/` (the Python subpackage).
# Pattern `dir/*` (not `dir/`) preserves the directory itself so `.gitkeep`
# can be re-included via a negation.
/data/*
!/data/.gitkeep
/artifacts/*
!/artifacts/.gitkeep
runs/
wandb/
checkpoints/
*.pt
*.pth
*.ckpt

# Hugging Face caches
.cache/
.huggingface/

# Personal / not part of the public repo
#   - The requirements brief is the instructor's intellectual property
#   - The reports/ folder holds the personal Report_<MSSV>_<HoTen>.pdf + LaTeX source + figures
requirement.md
reports/

